# ─── Application ──────────────────────────────────────────────────
NODE_ENV=development

# ─── Database (self-hosted via Coolify) ───────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/createflowchart

# ─── Redis (self-hosted via Coolify) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (Better Auth) ──────────────────────────────────────────
BETTER_AUTH_SECRET=your-random-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ─── AI Providers (multi-provider with priority fallback) ─────────
# OpenRouter (priority 1 — aggregates multiple providers)
OPENROUTER_API_KEY=sk-or-your-openrouter-key
OPENROUTER_MODELS=anthropic/claude-sonnet-4-20250514,openai/gpt-4o

# Direct OpenAI (priority 2 — fallback)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODELS=gpt-4o

# Direct Anthropic (priority 3 — fallback)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODELS=claude-sonnet-4-20250514

# Direct xAI / Grok (priority 4 — fallback)
XAI_API_KEY=xai-your-grok-key
XAI_MODELS=grok-3

# ─── Embeddings ───────────────────────────────────────────────────
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ─── Realtime Server ─────────────────────────────────────────────
REALTIME_PORT=4000
REALTIME_URL=ws://localhost:4000

# ─── Sentry (Error Tracking) ─────────────────────────────────────
SENTRY_DSN=your-sentry-dsn
