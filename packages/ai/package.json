{
  "name": "@createflowchart/ai",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@createflowchart/schema": "workspace:*",
    "@createflowchart/core": "workspace:*",
    "openai": "^4.80.0",
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@createflowchart/tsconfig": "workspace:*",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
